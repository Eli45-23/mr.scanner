# Official scanner identity. Give each machine a unique instance name.
SCANNER_INSTANCE_NAME=
SCANNER_MACHINE_ROLE=
SCANNER_ALERT_PROFILE=AAPL_TESTING

# Official alert scope
ALERT_SYMBOLS=AAPL
PHASE3_HEADS_UP_SYMBOLS=AAPL
MARKET_CONTEXT_SYMBOLS=SPY,QQQ

# Default product mode
ENABLE_OPTIONS_WHALE_SCANNER=true
ENABLE_LEGACY_MOMENTUM_SCANNER=false
OPTIONS_WHALE_FULL_MARKET=true
OPTIONS_WHALE_MAX_DTE=7
OPTIONS_WHALE_INCLUDE_0DTE=true
OPTIONS_WHALE_INCLUDE_WEEKLIES=true
OPTIONS_WHALE_MIN_SCORE=75
OPTIONS_WHALE_MIN_PREMIUM=100000
OPTIONS_WHALE_MIN_VOLUME=500
OPTIONS_WHALE_MIN_VOLUME_OI_RATIO=2.0
OPTIONS_WHALE_MAX_SPREAD_PERCENT=15
OPTIONS_WHALE_SCAN_INTERVAL_SECONDS=30
OPTIONS_WHALE_MAX_CONTRACTS_PER_SCAN=10000
OPTIONS_WHALE_MAX_RESULTS=100
OPTIONS_WHALE_ENABLE_SWEEP_DETECTION=true
OPTIONS_WHALE_ENABLE_BLOCK_DETECTION=true
OPTIONS_WHALE_ENABLE_MULTI_LEG_DETECTION=true
OPTIONS_WHALE_ENABLE_PRICE_ACTION_CONTEXT=true
OPTIONS_WHALE_ENABLE_NEXT_DAY_OI_REVIEW=true
OPTIONS_WHALE_ENABLE_NOTIFICATIONS=true
OPTIONS_WHALE_DEBUG_LOOSE_MODE=false
OPTIONS_WHALE_PRIORITY_SEEDS=SPY,QQQ,IWM,DIA,NVDA,AAPL,TSLA,AMD,MSFT,META,AMZN,GOOGL,NFLX,AVGO,COIN,MSTR,SMH,XLK,XLF,XLE,XLV,XLI,XLY,XLP,XLU,TLT,HYG,GLD,SLV
OPTIONS_WHALE_PRIORITY_BATCH_SIZE=50

# Alpaca market-data credentials
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_TRADING_BASE_URL=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
ALPACA_OPTIONS_CONTRACTS_BASE_URL=
ALPACA_OPTIONS_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_STOCK_FEED=sip
ALPACA_OPTIONS_FEED=opra
ALPACA_ALLOW_INDICATIVE_OPTIONS_FALLBACK=true
MAX_OPTION_QUOTE_AGE_SECONDS=60

# Optional AAPL news context. News never creates or upgrades alerts.
ENABLE_NEWS_CONTEXT_LAYER=false
NEWS_WATCH_SYMBOLS=AAPL
NEWS_LOOKBACK_MINUTES=120
NEWS_CONTEXT_ONLY=true

# Optional alert channels
DISCORD_WEBHOOK_URL=
ALERT_SMS_PHONE=
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# Telegram
ENABLE_TELEGRAM_ALERTS=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_TYPES=OPTIONS_WHALE_FLOW,PHASE3_HEADS_UP,STOCK_ONLY_WARNING,NORMAL_WATCH,NORMAL_SMS
TELEGRAM_AAPL_ONLY=true
TELEGRAM_SEND_TEST_ON_START=false
TELEGRAM_TIMEOUT_SECONDS=8
PHASE3_HEADS_UP_DEDUPE_MINUTES=15

# Scheduled AAPL morning preparation map. Uses the existing Telegram destination.
ENABLE_MORNING_PLAYBOOK=true
MORNING_PLAYBOOK_SEND_TIME_ET=09:25
MORNING_PLAYBOOK_TELEGRAM_ENABLED=true
MORNING_PLAYBOOK_MAX_CHARS=1200

# Scheduled AAPL market map context update. This is not a trade alert.
ENABLE_MARKET_MAP_UPDATE=true
MARKET_MAP_UPDATE_INTERVAL_MINUTES=10
MARKET_MAP_TELEGRAM_ENABLED=true
MARKET_MAP_MAX_CHARS=1200

# Optional AI dashboard review
OPENAI_API_KEY=
ENABLE_AI_REVIEW=false
ENABLE_OPENAI_ALERT_FORMATTER=true
OPENAI_ALERT_FORMATTER_STYLE=section
OPENAI_ALERT_FORMATTER_FALLBACK=true
OPENAI_ALERT_FORMATTER_MAX_CHARS=900

# Phase 1 live market-structure context engines. These do not approve trades.
ENABLE_SUPPORT_RESISTANCE_ENGINE=true
ENABLE_SUPPLY_DEMAND_ENGINE=true
ENABLE_MARKET_STRUCTURE_DASHBOARD=true
SUPPORT_RESISTANCE_TIMEFRAMES=1m,5m,15m
SUPPLY_DEMAND_TIMEFRAMES=1m,5m,15m
MAX_LEVELS_PER_TIMEFRAME=3
MAX_ZONES_PER_TIMEFRAME=3
MARKET_STRUCTURE_REFRESH_SECONDS=15
MARKET_STRUCTURE_MIN_LEVEL_STRENGTH=55
MARKET_STRUCTURE_MIN_ZONE_STRENGTH=55
MARKET_STRUCTURE_CAN_CONFIRM=true
MARKET_STRUCTURE_CAN_DOWNGRADE=true
MARKET_STRUCTURE_CAN_UPGRADE=false
ENABLE_MARKET_STRUCTURE_TELEGRAM=true
MARKET_STRUCTURE_TELEGRAM_MAX_LINES=2

# Decision-quality cleanup. These layers can only downgrade/suppress alerts.
ENABLE_CHOP_MODE=true
CHOP_MODE_LOOKBACK_MINUTES=15
CHOP_MODE_MIN_FLIPS=2
CHOP_MODE_MIN_MIXED_ALERTS=3
CHOP_MODE_SUPPRESS_REPEATED_ALERTS=true
CHOP_MODE_COOLDOWN_MINUTES=15
CHOP_MODE_ALLOW_BREAKOUT_EXIT=true
ENABLE_MISSED_CLEAN_ENTRY_LABEL=true
MISSED_CLEAN_ENTRY_LOOKBACK_MINUTES=15
MISSED_CLEAN_ENTRY_COOLDOWN_MINUTES=15

# Central final alert decision layer. It cannot approve trades.
ENABLE_ALERT_ORCHESTRATOR=true
TREND_CONTEXT_ALERTS_ENABLED=true
TREND_CONTEXT_MIN_SCORE=75
TREND_CONTEXT_MIN_TIMEFRAMES_ALIGNED=2
TREND_CONTEXT_ALLOW_THROUGH_CHOP=true
TREND_CONTEXT_COOLDOWN_MINUTES=15

# Final conservative notification gate. Only Tier 1 can reach Telegram/text.
ENABLE_ALERT_PRIORITY=true
TELEGRAM_ONLY_TIER_1=true
ALERT_PRIORITY_MIN_SCORE=80
ALERT_PRIORITY_DEDUPE_MINUTES=10

# Standalone warnings stay on dashboard/logs; first chop activation may text once.
WARNING_ALERT_FILTER_ENABLED=true
CHOP_ACTIVATION_TEXT_ONCE=true
MIXED_DASHBOARD_ONLY=true
DO_NOT_CHASE_DASHBOARD_ONLY=true
LATE_MOVE_DASHBOARD_ONLY=true

# Dedicated liquidity sweep context engine. It cannot approve trades.
ENABLE_LIQUIDITY_SWEEP_ENGINE=true
LIQUIDITY_SWEEP_TIMEFRAMES=1m,5m,15m
LIQUIDITY_SWEEP_MIN_CONFIDENCE=55
LIQUIDITY_SWEEP_CONFIRM_ON_CANDLE_CLOSE=true
LIQUIDITY_SWEEP_WATCH_DISTANCE_BPS=8
LIQUIDITY_SWEEP_COOLDOWN_MINUTES=10
LIQUIDITY_SWEEP_USE_SUPPLY_DEMAND=true
LIQUIDITY_SWEEP_USE_SUPPORT_RESISTANCE=true
LIQUIDITY_SWEEP_CAN_CONFIRM=true
LIQUIDITY_SWEEP_CAN_DOWNGRADE=true
LIQUIDITY_SWEEP_CAN_UPGRADE=false
LIQUIDITY_SWEEP_STRATEGY_LEGACY_FALLBACK=true
ENABLE_LIQUIDITY_SWEEP_TELEGRAM=true
LIQUIDITY_SWEEP_TELEGRAM_WATCH_ENABLED=false
LIQUIDITY_SWEEP_TELEGRAM_FORMING_ENABLED=true
LIQUIDITY_SWEEP_TELEGRAM_CONFIRMED_ENABLED=true
LIQUIDITY_SWEEP_TELEGRAM_FAILED_HELD_ENABLED=false
LIQUIDITY_SWEEP_TELEGRAM_FORMING_MIN_SCORE=70
LIQUIDITY_SWEEP_TELEGRAM_CONFIRMED_MIN_SCORE=80
LIQUIDITY_SWEEP_TELEGRAM_MIN_CONFIDENCE=MEDIUM
LIQUIDITY_SWEEP_TELEGRAM_CONFIRMED_MIN_CONFIDENCE=HIGH
LIQUIDITY_SWEEP_TELEGRAM_ZONE_BUCKET_BPS=12
LIQUIDITY_SWEEP_TELEGRAM_SAME_BUCKET_COOLDOWN_MINUTES=30
LIQUIDITY_SWEEP_TELEGRAM_SUPPRESS_REPEATED_RANGE_SWEEPS=true
LIQUIDITY_SWEEP_DASHBOARD_SHOW_MAP_ALWAYS=true
LIQUIDITY_SWEEP_TELEGRAM_COOLDOWN_MINUTES=10
LIQUIDITY_SWEEP_TELEGRAM_MAX_CHARS=900
LIQUIDITY_SWEEP_TELEGRAM_INCLUDE_STRUCTURE=true
LIQUIDITY_SWEEP_CONFIRMED_ONLY_TELEGRAM=true
LIQUIDITY_SWEEP_CONFIRMED_MIN_CONFIDENCE=70
LIQUIDITY_SWEEP_REQUIRE_MAJOR_LEVEL=true
