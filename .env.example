# Official scanner identity. Give each machine a unique instance name.
SCANNER_INSTANCE_NAME=
SCANNER_MACHINE_ROLE=
SCANNER_ALERT_PROFILE=AAPL_TESTING

# Official alert scope
ALERT_SYMBOLS=AAPL
PHASE3_HEADS_UP_SYMBOLS=AAPL
MARKET_CONTEXT_SYMBOLS=SPY,QQQ

# Alpaca market-data credentials
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_STOCK_FEED=sip
ALPACA_OPTIONS_FEED=opra
ALPACA_ALLOW_INDICATIVE_OPTIONS_FALLBACK=true
MAX_OPTION_QUOTE_AGE_SECONDS=60

# Optional AAPL news context. News never creates or upgrades alerts.
ENABLE_NEWS_CONTEXT_LAYER=false
NEWS_WATCH_SYMBOLS=AAPL
NEWS_LOOKBACK_MINUTES=120
NEWS_CONTEXT_ONLY=true

# Optional alert channels
DISCORD_WEBHOOK_URL=
ALERT_SMS_PHONE=
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# Telegram
ENABLE_TELEGRAM_ALERTS=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_TYPES=PHASE3_HEADS_UP,STOCK_ONLY_WARNING,NORMAL_WATCH,NORMAL_SMS
TELEGRAM_AAPL_ONLY=true
TELEGRAM_SEND_TEST_ON_START=false
TELEGRAM_TIMEOUT_SECONDS=8
PHASE3_HEADS_UP_DEDUPE_MINUTES=15

# Optional AI dashboard review
OPENAI_API_KEY=
ENABLE_AI_REVIEW=false
ENABLE_OPENAI_ALERT_FORMATTER=true
OPENAI_ALERT_FORMATTER_STYLE=section
OPENAI_ALERT_FORMATTER_FALLBACK=true
OPENAI_ALERT_FORMATTER_MAX_CHARS=900

# Phase 1 live market-structure context engines. These do not approve trades.
ENABLE_SUPPORT_RESISTANCE_ENGINE=true
ENABLE_SUPPLY_DEMAND_ENGINE=true
ENABLE_MARKET_STRUCTURE_DASHBOARD=true
SUPPORT_RESISTANCE_TIMEFRAMES=1m,5m,15m
SUPPLY_DEMAND_TIMEFRAMES=1m,5m,15m
MAX_LEVELS_PER_TIMEFRAME=3
MAX_ZONES_PER_TIMEFRAME=3
MARKET_STRUCTURE_REFRESH_SECONDS=15
MARKET_STRUCTURE_MIN_LEVEL_STRENGTH=55
MARKET_STRUCTURE_MIN_ZONE_STRENGTH=55
MARKET_STRUCTURE_CAN_CONFIRM=true
MARKET_STRUCTURE_CAN_DOWNGRADE=true
MARKET_STRUCTURE_CAN_UPGRADE=false
ENABLE_MARKET_STRUCTURE_TELEGRAM=true
MARKET_STRUCTURE_TELEGRAM_MAX_LINES=2

# Decision-quality cleanup. These layers can only downgrade/suppress alerts.
ENABLE_CHOP_MODE=true
CHOP_MODE_LOOKBACK_MINUTES=15
CHOP_MODE_MIN_FLIPS=2
CHOP_MODE_MIN_MIXED_ALERTS=3
CHOP_MODE_SUPPRESS_REPEATED_ALERTS=true
CHOP_MODE_COOLDOWN_MINUTES=15
CHOP_MODE_ALLOW_BREAKOUT_EXIT=true
ENABLE_MISSED_CLEAN_ENTRY_LABEL=true
MISSED_CLEAN_ENTRY_LOOKBACK_MINUTES=15
MISSED_CLEAN_ENTRY_COOLDOWN_MINUTES=15

# Dedicated liquidity sweep context engine. It cannot approve trades.
ENABLE_LIQUIDITY_SWEEP_ENGINE=true
LIQUIDITY_SWEEP_TIMEFRAMES=1m,5m,15m
LIQUIDITY_SWEEP_MIN_CONFIDENCE=55
LIQUIDITY_SWEEP_CONFIRM_ON_CANDLE_CLOSE=true
LIQUIDITY_SWEEP_WATCH_DISTANCE_BPS=8
LIQUIDITY_SWEEP_COOLDOWN_MINUTES=10
LIQUIDITY_SWEEP_USE_SUPPLY_DEMAND=true
LIQUIDITY_SWEEP_USE_SUPPORT_RESISTANCE=true
LIQUIDITY_SWEEP_CAN_CONFIRM=true
LIQUIDITY_SWEEP_CAN_DOWNGRADE=true
LIQUIDITY_SWEEP_CAN_UPGRADE=false
LIQUIDITY_SWEEP_STRATEGY_LEGACY_FALLBACK=true
ENABLE_LIQUIDITY_SWEEP_TELEGRAM=true
LIQUIDITY_SWEEP_TELEGRAM_WATCH_ENABLED=true
LIQUIDITY_SWEEP_TELEGRAM_FORMING_ENABLED=true
LIQUIDITY_SWEEP_TELEGRAM_CONFIRMED_ENABLED=true
LIQUIDITY_SWEEP_TELEGRAM_MIN_CONFIDENCE=55
LIQUIDITY_SWEEP_TELEGRAM_CONFIRMED_MIN_CONFIDENCE=65
LIQUIDITY_SWEEP_TELEGRAM_COOLDOWN_MINUTES=10
LIQUIDITY_SWEEP_TELEGRAM_MAX_CHARS=900
LIQUIDITY_SWEEP_TELEGRAM_INCLUDE_STRUCTURE=true
